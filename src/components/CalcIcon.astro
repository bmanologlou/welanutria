---
// Simple, consistent line icons per calculator. Pass `name` (the calc slug).
// Stroke inherits currentColor so CSS controls the color.
const { name } = Astro.props;

const icons = {
  tdee: '<circle cx="12" cy="12" r="8"/><path d="M12 12l3-3"/><path d="M12 4v1.5M12 18.5V20M4 12h1.5M18.5 12H20"/>',
  bmi: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 14a5 5 0 0 1 10 0"/><path d="M12 14l3-3"/>',
  'ideal-weight': '<path d="M6 9h12l-1.5 9h-9z"/><path d="M9 9a3 3 0 0 1 6 0"/><circle cx="12" cy="5" r="1.5"/>',
  protein: '<path d="M7 7c0 5 3 10 5 10s5-5 5-10a5 5 0 0 0-10 0z"/><path d="M9.5 8.5l5 5M14.5 8.5l-5 5"/>',
  water: '<path d="M12 3c3 4 6 7 6 10.5A6 6 0 0 1 6 13.5C6 10 9 7 12 3z"/>',
  'body-fat': '<path d="M9 4a3 3 0 0 0 6 0"/><path d="M7 8c0 0 1 2 5 2s5-2 5-2"/><path d="M8 8c-1 4-1 8 0 12M16 8c1 4 1 8 0 12"/>',
  'calorie-deficit': '<path d="M5 18l4-5 3 2 5-7"/><path d="M17 8h2v2"/><path d="M4 20h16"/>',
  'one-rep-max': '<path d="M4 9v6M20 9v6M7 7v10M17 7v10"/><path d="M7 12h10"/>',
  'calories-burned': '<path d="M12 3c1 3-1 4-1 6a3 3 0 0 0 6 0c0-1 0-2-1-3 2 2 3 4 3 7a7 7 0 0 1-14 0c0-4 3-6 4-9 0 2 1 2 1 2s-1-2-1-0z"/>',
};

const path = icons[name] || icons.tdee;
---
<svg class="calc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={path}></svg>

<style>
  .calc-icon{width:28px;height:28px;display:block}
</style>
