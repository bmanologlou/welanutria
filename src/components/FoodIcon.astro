const path = icons[category] || icons['Vegetables'];
---
<svg class="food-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={path}></svg>

<style>
  .food-icon{width:18px;height:18px;display:block;flex-shrink:0}
</style>
