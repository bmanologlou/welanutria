  'Eggs & dairy': '<path d="M12 22c-4.97 0-9-3.582-9-8 0-4.418 3-12 9-12s9 7.582 9 12-4.03 8-9 8Z"/>',
  'Legumes': '<path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8Z"/><path d="M14.1 6c-.9.8-2 2.3-2.6 3.5-.4.8-.8 2-1 3 2.1 0 3.5-.5 4.6-1.4 1.1-1 1.8-2.5 2.3-4.6-1.7-.3-2.8 0-3.3.5Z"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/>',
