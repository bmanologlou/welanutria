---
import Base from '../layouts/Base.astro';
import Faq from '../components/Faq.astro';
import CalcIcon from '../components/CalcIcon.astro';
import { getCollection } from 'astro:content';

// Three most recent blog articles for the homepage
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);

const calculators = [
  { href: '/calculators/tdee/', name: 'TDEE & Macros', desc: 'Daily calories and your protein, carb and fat split.' },
  { href: '/calculators/macros/', name: 'Macro Calculator', desc: 'Protein, carbs and fat, with adjustable splits.' },
  { href: '/calculators/bmr/', name: 'BMR', desc: 'The calories your body burns at complete rest.' },
  { href: '/calculators/bmi/', name: 'BMI', desc: 'Body mass index and what the range means.' },
  { href: '/calculators/ideal-weight/', name: 'Ideal Weight', desc: 'A healthy weight range for your height.' },
  { href: '/calculators/protein/', name: 'Protein', desc: 'How much protein you need each day.' },
  { href: '/calculators/water/', name: 'Water Intake', desc: 'Daily water target from your weight and activity.' },
  { href: '/calculators/body-fat/', name: 'Body Fat', desc: 'Estimate body fat with a tape measure.' },
  { href: '/calculators/calorie-deficit/', name: 'Calorie Deficit', desc: 'Plan weight loss at a pace that suits you.' },
  { href: '/calculators/one-rep-max/', name: 'One-Rep Max', desc: 'Estimate your 1RM and training loads.' },
  { href: '/calculators/calories-burned/', name: 'Calories Burned', desc: 'Calories burned during exercise, by activity.' },
];

// Featured comparisons: the strongest performers and newest additions
const comparisons = [
  { href: '/compare/greek-yogurt-vs-skyr/', a: 'Greek Yogurt', b: 'Skyr' },
  { href: '/compare/cottage-cheese-vs-greek-yogurt/', a: 'Cottage Cheese', b: 'Greek Yogurt' },
  { href: '/compare/oat-milk-vs-almond-milk/', a: 'Oat Milk', b: 'Almond Milk' },
  { href: '/compare/chicken-vs-turkey/', a: 'Chicken', b: 'Turkey' },
  { href: '/compare/brown-rice-vs-quinoa/', a: 'Brown Rice', b: 'Quinoa' },
  { href: '/compare/chickpeas-vs-lentils/', a: 'Chickpeas', b: 'Lentils' },
];

// Featured recipes
const featuredRecipes = [
  { slug: 'grilled-chicken-quinoa-bowl', name: 'Grilled Chicken & Quinoa Bowl', img: 'grilled-chicken-quinoa-bowl.webp', cal: 480, protein: 45 },
  { slug: 'salmon-roasted-vegetables', name: 'Baked Salmon with Roasted Vegetables', img: 'salmon-roasted-vegetables.webp', cal: 440, protein: 38 },
  { slug: 'greek-yogurt-protein-bowl', name: 'Greek Yogurt Protein Bowl', img: 'greek-yogurt-protein-bowl.webp', cal: 320, protein: 28 },
];

// Featured food lists
const foodLists = [
  { href: '/food-lists/high-protein-foods/', name: 'High-Protein Foods', count: 100 },
  { href: '/food-lists/high-fiber-foods/', name: 'High-Fibre Foods', count: 77 },
  { href: '/food-lists/high-protein-high-fiber-foods/', name: 'High-Protein High-Fibre', count: 41 },
  { href: '/food-lists/high-protein-snacks/', name: 'High-Protein Snacks', count: 80 },
  { href: '/food-lists/low-calorie-foods/', name: 'Low-Calorie Foods', count: 123 },
  { href: '/food-lists/gut-health-foods/', name: 'Gut Health Foods', count: 30 },
];

const faqs = [
  { q: 'Are the calculators free?', a: 'Yes. Every calculator on welanutria is completely free and works instantly in your browser, with no account or sign-up required.' },
  { q: 'How accurate are the results?', a: 'Each tool uses a recognised, published method and we tell you which one. Results are estimates with a stated margin of error, meant as a practical starting point rather than a precise measurement.' },
  { q: 'Is welanutria medical advice?', a: 'No. welanutria provides general information and estimates only. It is not a substitute for professional medical or dietary advice.' },
  { q: 'Do I need to create an account?', a: 'No. There are no accounts and nothing to sign up for. Just open a calculator and use it.' },
];
---
<Base
  title="TEST PAGE: welanutria home v2"
  description="Test version of the homepage. Not for indexing."
  current=""
>
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">Free · No sign-up</p>
        <h1>Your calories, macros and meals, all worked out.</h1>
        <p class="lede">Find your numbers in seconds with free, no-sign-up calculators, then turn them into real food with recipes and 7-day meal plans built to match. No guesswork, no accounts, just clear answers.</p>
        <div class="hero-cta">
          <a href="/calculators/tdee/" class="btn">Calculate my calories</a>
          <a href="/recipes/" class="btn btn-ghost">Browse recipes</a>
        </div>
      </div>
      <div class="hero-art">
        <img src="/img/wn-hero-photo.svg" alt="Illustration of healthy foods with nutrition data" width="740" height="500" loading="eager" />
      </div>
    </div>
  </section>

  <section class="wrap section">
    <h2 class="section-title">Calculators</h2>
    <p class="section-intro">Free, instant tools for the health numbers that matter most. Each one uses a recognised, published method and explains what your result means, so you get answers you can actually trust and act on.</p>
    <div class="grid">
      {calculators.map((c) => (
        <a class="tile" href={c.href}>
          <span class="tile-icon"><CalcIcon name={c.href.split('/').filter(Boolean).pop()} /></span>
          <span class="tile-name">{c.name}</span>
          <span class="tile-desc">{c.desc}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="wrap section">
    <h2 class="section-title">Food comparisons</h2>
    <p class="section-intro">Two foods, side by side, with the numbers that actually matter. See how they differ on calories, protein and key nutrients, and which one fits your goal.</p>
    <div class="vs-grid">
      {comparisons.map((c) => (
        <a class="vs-card" href={c.href}>
          <span class="vs-a">{c.a}</span>
          <span class="vs-mid">vs</span>
          <span class="vs-b">{c.b}</span>
        </a>
      ))}
    </div>
    <p class="section-more"><a href="/compare/">See all comparisons →</a></p>
  </section>

  <section class="wrap section">
    <h2 class="section-title">Recipes</h2>
    <p class="section-intro">High-protein, low-calorie and balanced recipes with full nutrition for every dish, so you can match your meals to your numbers.</p>
    <div class="recipe-grid">
      {featuredRecipes.map((r) => (
        <a class="recipe-card" href={`/recipes/${r.slug}/`}>
          <span class="recipe-img"><img src={`/img/recipes/${r.img}`} alt="" width="300" height="200" loading="lazy" /></span>
          <span class="recipe-body">
            <span class="recipe-name">{r.name}</span>
            <span class="recipe-macros">{r.cal} cal &middot; {r.protein}g protein</span>
          </span>
        </a>
      ))}
    </div>
    <div class="two-links">
      <a class="section-more-link" href="/recipes/">Browse all recipes &rarr;</a>
      <a class="section-more-link" href="/meal-plans/">See 7-day meal plans &rarr;</a>
    </div>
  </section>

  <section class="wrap section">
    <h2 class="section-title">Food lists</h2>
    <p class="section-intro">Ranked lists of the best foods for each goal, built from our database of 210 foods with the numbers per 100g and per serving.</p>
    <div class="list-grid">
      {foodLists.map((l) => (
        <a class="list-card" href={l.href}>
          <span class="list-name">{l.name}</span>
          <span class="list-count">{l.count} foods</span>
        </a>
      ))}
    </div>
    <p class="section-more"><a href="/food-lists/">See all food lists →</a></p>
  </section>

  <section class="wrap section">
    <h2 class="section-title">From the blog</h2>
    <p class="section-intro">Clear, practical guides on calories, protein and eating well, written to help you get more from the calculators and recipes.</p>
    <div class="post-grid">
      {latestPosts.map((post) => (
        <a class="post-card" href={`/blog/${post.slug}/`}>
          <span class="post-card-title">{post.data.title}</span>
          <span class="post-card-desc">{post.data.description}</span>
          <span class="post-card-link">Read more →</span>
        </a>
      ))}
    </div>
    <p class="section-more"><a href="/blog/">See all articles →</a></p>
  </section>

  <section class="wrap section">
    <Faq items={faqs} columns={2} />
  </section>

  <style>
    .hero{padding:64px 0 40px;background:linear-gradient(180deg,var(--cool) 0%,var(--paper) 100%)}
    .hero-inner{display:grid;grid-template-columns:1fr 540px;gap:36px;align-items:center}
    .hero h1{font-size:clamp(2rem,5vw,3.2rem);line-height:1.08;letter-spacing:-.03em;margin:.2em 0 .3em;max-width:14ch}
    .lede{font-size:1.15rem;color:#3F4F49;max-width:52ch;margin:0 0 28px}
    .hero-cta{display:flex;gap:12px;flex-wrap:wrap}
    .hero-art img{width:100%;height:auto;display:block}
    @media(max-width:1024px){
      .hero-inner{grid-template-columns:1fr 420px;gap:28px}
    }
    @media(max-width:860px){
      .hero{padding:48px 0 32px}
      .hero-inner{grid-template-columns:1fr;gap:28px}
      .hero h1{max-width:none}
      .hero-art{max-width:520px;margin:0 auto;width:100%}
    }
    @media(max-width:480px){
      .hero-cta{flex-direction:column}
      .hero-cta .btn{width:100%;text-align:center}
      .hero-art{max-width:100%}
    }

    .section{padding:44px 0 0}
    .section-title{font-size:1.5rem;letter-spacing:-.02em;margin:0 0 10px}
    .section-intro{color:#33433D;max-width:60ch;margin:0 0 22px;line-height:1.6}
    .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    @media(max-width:720px){.grid{grid-template-columns:repeat(2,1fr);gap:10px}}
    .tile{display:flex;flex-direction:column;gap:6px;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:18px 18px;transition:.15s}
    .tile-icon{color:var(--accent);margin-bottom:4px}
    .tile-icon :global(.calc-icon){width:30px;height:30px}
    .tile:hover{border-color:var(--accent);transform:translateY(-2px);text-decoration:none}
    .tile-name{font-weight:700;font-size:1.05rem;color:var(--ink)}
    .tile-desc{font-size:.9rem;color:var(--muted);line-height:1.45}
    .section-more{margin:18px 0 0}

    /* comparisons */
    .vs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    @media(max-width:820px){.vs-grid{grid-template-columns:repeat(2,1fr);gap:10px}}
    @media(max-width:480px){.vs-grid{grid-template-columns:1fr}}
    .vs-card{display:flex;align-items:baseline;justify-content:center;gap:10px;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:20px 16px;transition:.15s;text-align:center}
    .vs-card:hover{border-color:var(--accent);transform:translateY(-2px);text-decoration:none}
    .vs-a,.vs-b{font-weight:700;font-size:.98rem;color:var(--ink);line-height:1.3}
    .vs-mid{font-size:.78rem;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.06em;flex-shrink:0;line-height:1.3}

    /* food lists */
    .list-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    @media(max-width:820px){.list-grid{grid-template-columns:repeat(2,1fr);gap:10px}}
    @media(max-width:480px){.list-grid{grid-template-columns:1fr}}
    .list-card{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:20px 16px;transition:.15s;text-align:center}
    .list-card:hover{border-color:var(--accent);transform:translateY(-2px);text-decoration:none}
    .list-name{font-weight:700;font-size:.98rem;color:var(--ink);line-height:1.3}
    .list-count{font-size:.82rem;color:var(--muted)}

    /* recipes */
    .recipe-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    @media(max-width:820px){.recipe-grid{grid-template-columns:repeat(2,1fr);gap:10px}}
    @media(max-width:480px){.recipe-grid{grid-template-columns:1fr}}
    .recipe-card{display:flex;flex-direction:column;background:#fff;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;transition:.15s}
    .recipe-card:hover{border-color:var(--accent);transform:translateY(-2px);text-decoration:none}
    .recipe-img{display:block;line-height:0}
    .recipe-img img{width:100%;height:160px;object-fit:cover;display:block}
    .recipe-body{display:flex;flex-direction:column;gap:5px;padding:16px 18px}
    .recipe-name{font-weight:700;font-size:1rem;color:var(--ink);line-height:1.3}
    .recipe-macros{font-size:.85rem;color:var(--muted)}
    .two-links{display:flex;gap:24px;flex-wrap:wrap;margin:18px 0 0}
    .section-more-link{font-weight:600;color:var(--accent)}

    .split{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .feature{display:flex;flex-direction:column;border-radius:var(--radius);transition:.15s;border:1px solid var(--line);overflow:hidden}
    .feature:hover{transform:translateY(-2px);text-decoration:none}
    .feature-img{display:block;line-height:0}
    .feature-img img{width:100%;height:180px;object-fit:cover;display:block}
    .feature-body{display:flex;flex-direction:column;gap:8px;padding:24px}
    .feature h3{margin:.1em 0;font-size:1.3rem;letter-spacing:-.02em;color:var(--ink)}
    .feature p{margin:0;color:#3F4F49;font-size:.95rem}
    .feature-link{font-weight:600;color:var(--accent);margin-top:6px}
    .feature-warm{background:var(--amber-soft);border-color:#F0E3CB}
    .feature-warm2{background:#FBEEE0;border-color:#F2DcC4}
    @media(max-width:640px){.split{grid-template-columns:1fr}}

    .post-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    @media(max-width:720px){.post-grid{grid-template-columns:1fr}}
    .post-card{display:flex;flex-direction:column;gap:8px;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:22px 20px;transition:.15s;height:100%}
    .post-card:hover{border-color:var(--accent);transform:translateY(-2px);text-decoration:none}
    .post-card-title{font-weight:700;font-size:1.08rem;color:var(--ink);line-height:1.25}
    .post-card-desc{font-size:.9rem;color:var(--muted);line-height:1.5;flex:1}
    .post-card-link{font-weight:600;color:var(--accent);font-size:.88rem;margin-top:4px}
  </style>
</Base>
