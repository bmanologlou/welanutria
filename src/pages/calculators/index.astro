---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import CalcIcon from '../../components/CalcIcon.astro';

const calculators = [
  { href: '/calculators/tdee/', name: 'TDEE & Macros', desc: 'Your daily calories and a protein, carb and fat split for your goal.', ready: true },
  { href: '/calculators/bmi/', name: 'BMI', desc: 'Body mass index and what the range means for you.', ready: true },
  { href: '/calculators/ideal-weight/', name: 'Ideal Weight', desc: 'A healthy weight range based on your height.', ready: true },
  { href: '/calculators/protein/', name: 'Protein', desc: 'How much protein you need each day.', ready: true },
  { href: '/calculators/water/', name: 'Water Intake', desc: 'A daily water target from your weight and activity.', ready: true },
  { href: '/calculators/body-fat/', name: 'Body Fat', desc: 'Estimate body fat with a few tape measurements.', ready: true },
  { href: '/calculators/calorie-deficit/', name: 'Calorie Deficit', desc: 'The daily deficit to lose weight at your chosen pace.', ready: true },
  { href: '/calculators/one-rep-max/', name: 'One-Rep Max', desc: 'Estimate your 1RM and training percentages.', ready: true },
  { href: '/calculators/calories-burned/', name: 'Calories Burned', desc: 'Calories burned during exercise, by activity.', ready: true },
];

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Health & fitness calculators',
  itemListElement: calculators.filter((c) => c.ready).map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    url: 'https://welanutria.com' + c.href,
  })),
};
---
<Base
  title="Free Health & Fitness Calculators | welanutria"
  description="Free calculators for calories, macros, BMI, ideal weight, protein, water intake and body fat. No sign-up, instant results, each method explained."
  current="calculators"
>
  <JsonLd schema={itemList} />
  <div class="wrap idx">
    <header class="idx-head">
      <p class="eyebrow">Calculators</p>
      <h1>Health &amp; fitness calculators</h1>
      <p class="lede">Fast, free tools for the numbers that matter, calories, macros, weight and more. Each one is backed by a recognised method and explained in plain language.</p>
    </header>

    <div class="idx-grid">
      {calculators.map((c) => (
        c.ready ? (
          <a class="idx-tile" href={c.href}>
            <span class="idx-icon"><CalcIcon name={c.href.split('/').filter(Boolean).pop()} /></span>
            <span class="idx-name">{c.name}</span>
            <span class="idx-desc">{c.desc}</span>
            <span class="idx-go">Open →</span>
          </a>
        ) : (
          <div class="idx-tile soon">
            <span class="idx-icon"><CalcIcon name={c.href.split('/').filter(Boolean).pop()} /></span>
            <span class="idx-name">{c.name}</span>
            <span class="idx-desc">{c.desc}</span>
            <span class="idx-soon">Coming soon</span>
          </div>
        )
      ))}
    </div>

    <section class="idx-intro">
      <h2>Tools you can trust, explained in plain language</h2>
      <p>Most online calculators hand you a number and leave you guessing. welanutria does the opposite: every tool tells you which method it uses, what the result means, and how confident you can be in it. Our calculators draw on recognised, published formulas, the Mifflin-St Jeor equation for daily calories, the U.S. Navy method for body fat, and standard dietary references for protein and water, so you get answers grounded in real science rather than guesswork.</p>
      <p>Whether you're working out how many calories you need, checking a healthy weight range, or dialling in your protein, each calculator works instantly in your browser with no sign-up. Pair them together for a fuller picture, start with <a href="/calculators/tdee/">your daily calories</a>, then use the results to plan meals that fit. Remember that every result is an estimate for general guidance, not a medical diagnosis.</p>
    </section>
  </div>

  <style>
    .idx{padding:40px 0 0}
    .idx-head{margin-bottom:26px}
    .idx-head h1{font-size:clamp(1.8rem,4vw,2.4rem);letter-spacing:-.02em;margin:.1em 0 .3em}
    .idx-head .lede{color:#33433D;max-width:58ch;margin:0;font-size:1.05rem}
    .idx-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    @media(max-width:720px){.idx-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:460px){.idx-grid{grid-template-columns:1fr}}
    .idx-tile{display:flex;flex-direction:column;gap:6px;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:18px;transition:.15s}
    .idx-icon{color:var(--accent);margin-bottom:4px}
    .idx-icon :global(.calc-icon){width:30px;height:30px}
    a.idx-tile:hover{border-color:var(--accent);transform:translateY(-2px);text-decoration:none}
    .idx-name{font-weight:700;font-size:1.08rem;color:var(--ink)}
    .idx-desc{font-size:.9rem;color:var(--muted);line-height:1.45;flex:1}
    .idx-go{font-weight:600;color:var(--accent);font-size:.9rem;margin-top:4px}
    .idx-tile.soon{opacity:.7}
    .idx-soon{font-size:.78rem;color:var(--muted);font-weight:600;margin-top:4px}
    .idx-intro{max-width:68ch;margin:36px 0 0}
    .idx-intro h2{font-size:1.3rem;letter-spacing:-.01em;margin:0 0 .5em}
    .idx-intro p{color:#33433D;line-height:1.65;margin:0 0 1em}
    .idx-intro a{font-weight:500}
  </style>
</Base>
