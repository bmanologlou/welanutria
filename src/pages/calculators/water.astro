---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import Faq from '../../components/Faq.astro';

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Water Intake Calculator',
  url: 'https://welanutria.com/calculators/water/',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Estimate how much water to drink each day based on your weight and exercise.',
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Calculators', item: 'https://welanutria.com/calculators/' },
    { '@type': 'ListItem', position: 2, name: 'Water Intake', item: 'https://welanutria.com/calculators/water/' },
  ],
};

const faqs = [
  { q: 'How much water should I drink a day?', a: 'A common guideline is roughly 30 to 35 ml per kilogram of body weight, plus extra for exercise. This calculator uses your weight and activity to give a personal estimate, but needs also vary with climate, health and diet.' },
  { q: 'Does food count toward water intake?', a: 'Yes. Around 20 percent of your daily water typically comes from food, especially fruits and vegetables. The figure here is a total target; you do not need to drink all of it as plain water.' },
  { q: 'Can I drink too much water?', a: 'In rare cases, drinking very large amounts in a short time can be harmful. For most people, spreading intake through the day and drinking to thirst is a safe approach.' },
  { q: 'Is this medical advice?', a: 'No. welanutria provides estimates for general information only. If you have a health condition affecting fluid intake, follow your healthcare provider.' },
];
---
<Base
  title="Water Intake Calculator — Daily Water Needs | welanutria"
  description="Free water intake calculator. Estimate how much water to drink each day based on your weight and exercise level."
  current="calculators"
>
  <JsonLd schema={appSchema} />
  <JsonLd schema={breadcrumb} />

  <div class="calc-page wrap">
    <nav class="crumbs"><a href="/calculators/">Calculators</a> / <span>Water Intake</span></nav>

    <header class="calc-head">
      <p class="eyebrow">Calculator</p>
      <h1>Water Intake Calculator</h1>
      <p class="lede">A simple daily water target based on your body weight and how much you exercise. Hydration needs vary, so treat it as a helpful guide.</p>
    </header>

    <div class="calc-grid">
      <section class="panel">
        <h2 class="panel-title">Your details</h2>
        <div class="field"><label>Units</label>
          <div class="seg" id="seg-units">
            <button type="button" data-u="metric" aria-pressed="true">Metric</button>
            <button type="button" data-u="imperial" aria-pressed="false">Imperial</button>
          </div>
        </div>
        <div class="row">
          <div class="field"><label id="w-label">Weight (kg)</label>
            <div class="stepper"><button type="button" data-step="-1" aria-label="Decrease weight">−</button><input type="number" id="weight" value="75"><button type="button" data-step="1" aria-label="Increase weight">+</button></div>
          </div>
          <div class="field"><label>Exercise (min / day)</label>
            <div class="stepper"><button type="button" data-step="-1" aria-label="Decrease exercise">−</button><input type="number" id="exercise" value="30" min="0" max="300"><button type="button" data-step="1" aria-label="Increase exercise">+</button></div>
          </div>
        </div>
      </section>

      <section class="panel result cool-panel">
        <h2 class="panel-title">Daily water</h2>
        <div class="big-result">
          <span class="big-num" id="r-water">2.6</span>
          <span class="big-lbl" id="r-unit">litres / day</span>
        </div>
        <p class="r-context" id="r-context">About <strong id="r-glasses">10</strong> glasses (250 ml each).</p>
        <p class="margin-note">A guide based on weight and activity. Climate, health and diet also affect how much you need.</p>
      </section>
    </div>

    <section class="explainer">
      <h2>How much water do you really need?</h2>
      <p>You'll often hear "eight glasses a day", but real needs depend on your <strong>body size and activity</strong>. A larger body and more exercise mean more water lost and more to replace. This calculator starts from your weight and adds an allowance for exercise to give a more personal target than a one-size-fits-all rule.</p>

      <h2>Tips for staying hydrated</h2>
      <p>Spread your intake through the day rather than forcing large amounts at once, drink more in hot weather or when training hard, and remember that water-rich foods like fruit and vegetables count too. A practical sign of good hydration is pale-yellow urine.</p>

      <div class="next-links">
        <h3>Next steps</h3>
        <ul>
          <li><a href="/calculators/tdee/">TDEE &amp; macros</a> — your daily calorie needs</li>
          <li><a href="/calculators/protein/">Protein calculator</a> — your daily protein target</li>
        </ul>
      </div>
    </section>

    <div class="faq-wrap"><Faq items={faqs} /></div>

    <p class="page-disclaimer">welanutria provides estimates for general information only and is not medical advice.</p>
  </div>

  <style>
    .calc-page{padding:28px 0 0}
    .crumbs{font-size:.82rem;color:var(--muted);margin-bottom:14px}.crumbs a{color:var(--muted)}
    .calc-head{margin-bottom:24px}
    .calc-head h1{font-size:clamp(1.7rem,4vw,2.3rem);letter-spacing:-.02em;margin:.1em 0 .3em}
    .calc-head .lede{color:#33433D;max-width:60ch;margin:0;font-size:1.02rem}
    .calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:stretch}
    @media(max-width:780px){.calc-grid{grid-template-columns:1fr;align-items:start}}
    .panel-title{font-size:.76rem;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);margin:0 0 16px;font-weight:700}
    .field{margin-bottom:16px}.field label{display:block;font-weight:600;font-size:.9rem;margin-bottom:7px}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:13px}
    @media(max-width:460px){.row{grid-template-columns:1fr}}
    .seg{display:flex;border:1px solid var(--line);border-radius:10px;overflow:hidden;background:var(--field)}
    .seg button{flex:1;border:none;background:transparent;padding:10px;font:inherit;font-weight:600;font-size:.9rem;color:var(--muted);cursor:pointer;transition:.12s}
    .seg button[aria-pressed=true]{background:var(--accent);color:#fff}
    .stepper{display:flex;align-items:stretch;border:1px solid var(--line);border-radius:10px;overflow:hidden;background:var(--field)}
    .stepper input{border:none;border-radius:0;text-align:center;background:transparent;padding:11px 4px;font:inherit;font-size:1rem;width:100%;color:var(--ink);-moz-appearance:textfield}
    .stepper input::-webkit-outer-spin-button,.stepper input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}
    .stepper input:focus{outline:none}.stepper:focus-within{outline:2px solid var(--accent);outline-offset:1px}
    .stepper button{flex:none;width:38px;border:none;background:transparent;color:var(--accent);font-size:1.25rem;font-weight:600;cursor:pointer;transition:.12s;display:flex;align-items:center;justify-content:center}
    .stepper button:hover{background:#C4DDD5}
    .result{background:var(--cool-2);border-color:var(--cool-line)}
    .big-result{display:flex;align-items:baseline;gap:8px;margin-bottom:4px}
    .big-num{font-size:2.6rem;font-weight:800;letter-spacing:-.03em;color:var(--accent)}
    .big-lbl{font-size:.95rem;color:var(--muted)}
    .r-context{color:#33433D;font-size:.95rem;margin:0 0 16px}
    .margin-note{font-size:.78rem;color:var(--muted);margin:0;line-height:1.5}
    .explainer{max-width:calc((100% - 16px) / 2);margin:28px 0 0}
    .faq-wrap{max-width:calc((100% - 16px) / 2)}
    @media(max-width:780px){.explainer,.page-disclaimer,.faq-wrap{max-width:100%}}
    .explainer h2{font-size:1.3rem;letter-spacing:-.01em;margin:1.6em 0 .4em}
    .explainer h3{font-size:1.05rem;margin:1.4em 0 .4em}
    .explainer p{color:#33433D;line-height:1.65;margin:0 0 1em}
    .next-links{background:var(--paper-2);border:1px solid var(--line);border-radius:12px;padding:16px 18px;margin-top:18px}
    .next-links h3{margin:0 0 8px}.next-links ul{margin:0;padding-left:1.2em;line-height:1.7}.next-links a{font-weight:500}
    .page-disclaimer{max-width:calc((100% - 16px) / 2);font-size:.78rem;color:var(--muted);margin:24px 0 0;padding-top:16px;border-top:1px solid var(--line);line-height:1.5}
  </style>

  <script>
    (function(){
      const $=(id)=>document.getElementById(id);
      let units='metric';
      $('seg-units').addEventListener('click',(e)=>{
        const b=e.target.closest('button'); if(!b)return;
        const nu=b.dataset.u; if(nu===units)return;
        const w=$('weight');
        if(nu==='imperial'){ w.value=Math.round(parseFloat(w.value)*2.2046); $('w-label').textContent='Weight (lb)'; }
        else { w.value=Math.round(parseFloat(w.value)/2.2046); $('w-label').textContent='Weight (kg)'; }
        units=nu;
        [...$('seg-units').children].forEach(x=>x.setAttribute('aria-pressed',x===b?'true':'false'));
        calc();
      });
      document.addEventListener('click',(e)=>{
        const btn=e.target.closest('.stepper button'); if(!btn)return;
        const input=btn.parentElement.querySelector('input');
        const step=parseFloat(btn.dataset.step)||1;
        let v=(parseFloat(input.value)||0)+step;
        const min=input.min!==''?parseFloat(input.min):-Infinity;
        const max=input.max!==''?parseFloat(input.max):Infinity;
        if(v<min)v=min; if(v>max)v=max; input.value=v; calc();
      });
      $('weight').addEventListener('input',calc);
      $('exercise').addEventListener('input',calc);
      function calc(){
        let w=parseFloat($('weight').value)||0;
        if(units==='imperial'){ w=w/2.2046; }
        const ex=parseFloat($('exercise').value)||0;
        // ~33 ml/kg + ~12 ml per minute of exercise
        let ml = w*33 + ex*12;
        let litres = ml/1000;
        const glasses = Math.round(ml/250);
        if(units==='imperial'){
          const oz = ml/29.5735;
          $('r-water').textContent = (oz/8).toFixed(1); // cups (8oz)
          $('r-unit').textContent = 'cups / day';
        } else {
          $('r-water').textContent = litres.toFixed(1);
          $('r-unit').textContent = 'litres / day';
        }
        $('r-glasses').textContent = glasses;
      }
      calc();
    })();
  </script>
</Base>
