---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import Faq from '../../components/Faq.astro';
import { comparisons, getComparison, comparisonFoods, COMPARE_ROWS } from '../../data/comparisons.js';
import { foodLists } from '../../data/foodLists.js';
import { recipes } from '../../data/recipes.js';

export async function getStaticPaths() {
  return comparisons.map((c) => ({
    params: { slug: c.slug },
    props: { comparison: c },
  }));
}

const { comparison } = Astro.props;
const url = `https://welanutria.com/compare/${comparison.slug}/`;
const { a, b } = comparisonFoods(comparison);

// Decide which side "wins" each row (higher is better, except calories/sugar/fat where lower is better)
const lowerBetter = ['cal', 'sugar', 'fat'];
const rows = COMPARE_ROWS.map((r) => {
  const av = a[r.key], bv = b[r.key];
  let winner = null;
  if (av !== bv) {
    const aWins = lowerBetter.includes(r.key) ? av < bv : av > bv;
    winner = aWins ? 'a' : 'b';
  }
  return { ...r, av, bv, winner };
});

// Related content lookups
const relLists = (comparison.related?.lists || [])
  .map((slug) => foodLists.find((l) => l.slug === slug))
  .filter(Boolean);
const relRecipes = (comparison.related?.recipes || [])
  .map((slug) => recipes.find((r) => r.slug === slug))
  .filter(Boolean);
const relArticle = comparison.related?.article || null;
const relCalculator = comparison.related?.calculator || null;
const hasRelated = relLists.length > 0 || relRecipes.length > 0 || relArticle || relCalculator;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Compare', item: 'https://welanutria.com/compare/' },
    { '@type': 'ListItem', position: 2, name: comparison.title, item: url },
  ],
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: comparison.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Base title={`${comparison.title}: Full Nutrition Comparison | welanutria`} description={comparison.description} current="compare">
  <JsonLd schema={breadcrumb} />
  <JsonLd schema={faqSchema} />

  <article class="cmp wrap">
    <nav class="crumbs"><a href="/compare/">Compare</a> / <span>{comparison.title}</span></nav>

    <header class="cmp-head">
      <h1>{comparison.title}</h1>
      <p class="lede">{comparison.intro}</p>
      <div class="share-row">
        <button class="share-btn" id="shareBtn" type="button" aria-label="Share">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"/><line x1="15.4" y1="6.5" x2="8.6" y2="10.5"/></svg>
          Share
        </button>
        <button class="share-btn" id="printBtn" type="button" aria-label="Print">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Print
        </button>
      </div>
    </header>

    <p class="per-note">Nutrition per 100 g. Highlighted cell is the higher (or, for calories, sugar and fat, the lower) of the two.</p>

    <div class="table-wrap">
      <table class="cmp-table">
        <thead>
          <tr>
            <th class="th-nutrient">Per 100 g</th>
            <th>{comparison.labelA}</th>
            <th>{comparison.labelB}</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="td-nutrient">{r.label}</td>
              <td class={r.winner === 'a' ? 'td-win' : ''}>{r.av}{r.unit === 'kcal' ? '' : ' ' + r.unit}{r.unit === 'kcal' ? ' kcal' : ''}</td>
              <td class={r.winner === 'b' ? 'td-win' : ''}>{r.bv}{r.unit === 'kcal' ? '' : ' ' + r.unit}{r.unit === 'kcal' ? ' kcal' : ''}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <section class="verdict">
      <h2>The verdict</h2>
      <p>{comparison.verdict}</p>
    </section>

    <div class="choose">
      <div class="choose-card">
        <span class="choose-label">{comparison.labelA}</span>
        <p>{comparison.chooseA}</p>
      </div>
      <div class="choose-card">
        <span class="choose-label">{comparison.labelB}</span>
        <p>{comparison.chooseB}</p>
      </div>
    </div>

    {hasRelated && (
      <section class="cmp-related">
        <h2>Related</h2>
        <div class="rel-grid">
          {relCalculator && (
            <a class="rel-chip rel-calc" href={relCalculator.href}>{relCalculator.name}</a>
          )}
          {relArticle && (
            <a class="rel-chip rel-article" href={relArticle.href}>{relArticle.name}</a>
          )}
          {relLists.map((l) => (
            <a class="rel-chip rel-list" href={`/food-lists/${l.slug}/`}>{l.title}</a>
          ))}
          {relRecipes.map((r) => (
            <a class="rel-chip rel-recipe" href={`/recipes/${r.slug}/`}>{r.title}</a>
          ))}
        </div>
      </section>
    )}

    <section class="cmp-faq">
      <h2>Frequently asked questions</h2>
      <Faq items={comparison.faqs} />
    </section>

    <p class="cmp-disclaimer">Nutrition values are per 100 g from typical USDA data and vary with variety, cut and preparation. This is general information, not dietary advice.</p>
    <p class="print-credit">Copywriting by welanutria.com · {url}</p>
  </article>

  <style>
    .cmp{padding:32px 0 0;max-width:820px}
    .crumbs{font-size:.82rem;color:var(--muted);margin-bottom:16px}
    .crumbs a{color:var(--muted)}
    .cmp-head h1{font-size:clamp(1.9rem,4.5vw,2.6rem);letter-spacing:-.02em;line-height:1.12;margin:0 0 .3em}
    .cmp-head .lede{font-size:1.12rem;color:#33433D;margin:0;line-height:1.6}
    .share-row{display:flex;gap:10px;margin-top:16px}
    .share-btn{display:inline-flex;align-items:center;gap:7px;background:#fff;border:1px solid var(--line);color:var(--ink);font-size:.85rem;font-weight:600;font-family:inherit;padding:8px 14px;border-radius:9px;cursor:pointer;transition:.15s}
    .share-btn:hover{border-color:var(--accent);color:var(--accent)}
    .share-btn svg{color:var(--accent)}

    .per-note{font-size:.8rem;color:var(--muted);margin:24px 0 10px}
    .table-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:14px}
    .cmp-table{width:100%;border-collapse:collapse;font-size:.95rem}
    .cmp-table th,.cmp-table td{padding:12px 16px;text-align:center;border-bottom:1px solid var(--line)}
    .cmp-table thead th{background:var(--paper-2);font-size:.9rem;color:var(--ink);font-weight:700}
    .th-nutrient,.td-nutrient{text-align:left !important;font-weight:600;color:var(--ink)}
    .cmp-table tbody tr:last-child td{border-bottom:none}
    .td-win{background:var(--amber-soft);font-weight:700;color:var(--accent-deep)}

    .verdict{margin:32px 0 0}
    .verdict h2{font-size:1.4rem;margin:0 0 .4em}
    .verdict p{margin:0;line-height:1.7;color:var(--body)}

    .choose{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:24px 0 0}
    @media(max-width:600px){.choose{grid-template-columns:1fr}}
    .choose-card{background:var(--paper-2);border:1px solid var(--line);border-radius:12px;padding:18px 20px}
    .choose-label{font-weight:700;color:var(--accent-deep);font-size:1.05rem;display:block;margin-bottom:6px}
    .choose-card p{margin:0;font-size:.95rem;line-height:1.55;color:var(--body)}

    .cmp-related{margin:32px 0 0}
    .cmp-related h2{font-size:1.4rem;margin:0 0 .5em}
    .rel-grid{display:flex;flex-wrap:wrap;gap:10px}
    .rel-chip{display:inline-block;padding:9px 16px;border-radius:24px;font-size:.9rem;font-weight:600;border:1px solid var(--line);transition:.15s}
    .rel-list{background:var(--cool-2);color:var(--accent-deep);border-color:var(--cool-line)}
    .rel-recipe{background:var(--amber-soft);color:var(--accent-deep);border-color:#F0E3CB}
    .rel-calc{background:var(--cool);color:var(--accent-deep);border-color:var(--cool-line)}
    .rel-article{background:var(--paper-2);color:var(--accent-deep);border-color:var(--line)}
    .rel-chip:hover{transform:translateY(-2px);text-decoration:none;border-color:var(--accent)}

    .cmp-faq{margin:36px 0 0}
    .cmp-faq h2{font-size:1.4rem;margin:0 0 .5em}

    .cmp-disclaimer{font-size:.78rem;color:var(--muted);margin:28px 0 0;padding-top:16px;border-top:1px solid var(--line);line-height:1.5}
    .print-credit{display:none}
    @media print{
      .site-header,.site-footer,.share-row,.cmp-related,.crumbs{display:none !important}
      .cmp{padding:0}
      a{color:#000 !important}
      .print-credit{display:block;margin-top:24px;padding-top:12px;border-top:1px solid #ccc;font-size:.8rem;color:#555;text-align:center}
    }
  </style>

  <script>
    const shareBtn = document.getElementById('shareBtn');
    const printBtn = document.getElementById('printBtn');
    const pageUrl = window.location.href;
    const pageTitle = document.title;
    if (shareBtn) {
      if (navigator.share) {
        shareBtn.addEventListener('click', async () => { try { await navigator.share({ title: pageTitle, url: pageUrl }); } catch(e){} });
      } else {
        shareBtn.addEventListener('click', async () => {
          try { await navigator.clipboard.writeText(pageUrl);
            const label = shareBtn.childNodes[shareBtn.childNodes.length-1];
            const o = label.textContent; label.textContent=' Copied!';
            setTimeout(()=>{label.textContent=o;},1800);
          } catch(e){}
        });
      }
    }
    if (printBtn) printBtn.addEventListener('click', () => window.print());
  </script>
</Base>
