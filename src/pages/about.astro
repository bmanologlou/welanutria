import JsonLd from '../components/JsonLd.astro';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About welanutria',
  url: 'https://welanutria.com/about/',
  description: 'What welanutria is, who it is for, and the principles behind our free health and fitness calculators and recipes.',
  mainEntity: {
    '@type': 'Organization',
    name: 'welanutria',
    url: 'https://welanutria.com/',
    email: 'hello@welanutria.com',
    description: 'A free collection of health and fitness calculators and recipes, each backed by a recognised method and clearly explained.',
