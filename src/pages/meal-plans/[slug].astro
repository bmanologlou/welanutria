---
import Base from '../../layouts/Base.astro';
import JsonLd from '../../components/JsonLd.astro';
import { mealPlans, getMealPlan, dayTotals, planAverage } from '../../data/mealPlans.js';

export async function getStaticPaths() {
  return mealPlans.map((plan) => ({
    params: { slug: plan.slug },
    props: { plan },
  }));
}

const { plan } = Astro.props;
const url = `https://welanutria.com/meal-plans/${plan.slug}/`;
const avg = planAverage(plan);
const dayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Meal Plans', item: 'https://welanutria.com/meal-plans/' },
    { '@type': 'ListItem', position: 2, name: plan.title, item: url },
  ],
};
---
<Base title={`${plan.h1} | welanutria`} description={plan.description} current="meal-plans">
  <JsonLd schema={breadcrumb} />

  <article class="plan wrap">
    <nav class="crumbs"><a href="/meal-plans/">Meal Plans</a> / <span>{plan.title}</span></nav>

    <header class="plan-head">
      <div class="tags">{plan.tags.map((t) => <span class="tag">{t}</span>)}</div>
      <h1>{plan.h1}</h1>
      <p class="lede">{plan.intro}</p>
      <div class="share-row">
        <button class="share-btn" id="shareBtn" type="button" aria-label="Share this plan">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"/><line x1="15.4" y1="6.5" x2="8.6" y2="10.5"/></svg>
          Share
        </button>
        <button class="share-btn" id="printBtn" type="button" aria-label="Print this plan">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Print
        </button>
      </div>
    </header>

    <div class="avg-bar">
      <div class="avg-cell avg-cal"><span class="ac-val">{avg.cal}</span><span class="ac-label">kcal</span></div>
      <div class="avg-cell"><span class="ac-val">{avg.protein}g</span><span class="ac-label">Protein</span></div>
      <div class="avg-cell"><span class="ac-val">{avg.carbs}g</span><span class="ac-label">Carbs</span></div>
      <div class="avg-cell"><span class="ac-val">{avg.fat}g</span><span class="ac-label">Fat</span></div>
    </div>
    <p class="avg-note">Average per day across the week ({plan.target})</p>

    <div class="days">
      {plan.days.map((d, i) => {
        const t = dayTotals(d);
        return (
          <section class="day-card">
            <div class="day-head">
              <h2>{dayNames[i]}</h2>
              <span class="day-total">{t.cal} kcal · {t.protein}g protein</span>
            </div>
            <ul class="meal-list">
              {d.meals.map((m) => (
                <li class="meal-row">
                  <span class="meal-type">{m.type}</span>
                  <a class="meal-name" href={`/recipes/${m.slug}/`}>{m.title}</a>
                  <span class="meal-cal">{m.cal} kcal</span>
                </li>
              ))}
              {d.extras && d.extras.items.length > 0 && (
                <li class="meal-row meal-extra">
                  <span class="meal-type">Extras</span>
                  <span class="meal-name meal-extra-note">{d.extras.items.map((it) => it.label).join(', ')}</span>
                  <span class="meal-cal">{d.extras.cal} kcal</span>
                </li>
              )}
            </ul>
          </section>
        );
      })}
    </div>

    <div class="plan-related">
      <a class="pr-card pr-calc" href={plan.relatedCalculator.href}>
        <span class="pr-kicker">Find your numbers</span>
        <span class="pr-title">{plan.relatedCalculator.name}</span>
        <span class="pr-go">Open the calculator →</span>
      </a>
      <a class="pr-card pr-recipes" href="/recipes/">
        <span class="pr-kicker">Browse all</span>
        <span class="pr-title">Explore the full recipe collection</span>
        <span class="pr-go">See all recipes →</span>
      </a>
    </div>

    <p class="plan-disclaimer">This meal plan is a general guide, not personalised nutrition advice. Calorie and macro values are estimates calculated from typical ingredient values and may vary. Adjust portions to your own needs, and consult a qualified professional for tailored advice.</p>
    <p class="print-credit">Copywriting by welanutria.com · {url}</p>
  </article>

  <style>
    .plan{padding:32px 0 0;max-width:820px}
    .crumbs{font-size:.82rem;color:var(--muted);margin-bottom:16px}
    .crumbs a{color:var(--muted)}
    .plan-head{margin-bottom:20px}
    .tags{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:12px}
    .tag{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--accent-deep);background:var(--amber-soft);border:1px solid #F0E3CB;border-radius:20px;padding:4px 11px}
    .plan-head h1{font-size:clamp(1.9rem,4.5vw,2.6rem);letter-spacing:-.02em;line-height:1.12;margin:0 0 .3em}
    .plan-head .lede{font-size:1.12rem;color:#33433D;margin:0;line-height:1.6}
    .share-row{display:flex;gap:10px;margin-top:16px}
    .share-btn{display:inline-flex;align-items:center;gap:7px;background:#fff;border:1px solid var(--line);color:var(--ink);font-size:.85rem;font-weight:600;font-family:inherit;padding:8px 14px;border-radius:9px;cursor:pointer;transition:.15s}
    .share-btn:hover{border-color:var(--accent);color:var(--accent)}
    .share-btn svg{color:var(--accent)}

    .avg-bar{display:flex;background:var(--accent);border-radius:12px;overflow:hidden;margin:22px 0 6px}
    .avg-cell{flex:1;display:flex;flex-direction:column;gap:1px;padding:14px 12px;text-align:center;border-right:1px solid rgba(255,255,255,.18)}
    .avg-cell:last-child{border-right:none}
    .ac-val{font-size:1.2rem;font-weight:800;color:#fff}
    .ac-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:rgba(255,255,255,.85);font-weight:600}
    .avg-cal{background:var(--accent-deep)}
    .avg-note{font-size:.78rem;color:var(--muted);margin:0 0 28px;text-align:right}

    .days{display:flex;flex-direction:column;gap:16px}
    .day-card{border:1px solid var(--line);border-radius:14px;overflow:hidden}
    .day-head{display:flex;justify-content:space-between;align-items:center;background:var(--paper-2);padding:12px 18px;border-bottom:1px solid var(--line)}
    .day-head h2{font-size:1.15rem;margin:0;color:var(--ink)}
    .day-total{font-size:.85rem;color:var(--accent-deep);font-weight:700}
    .meal-list{list-style:none;margin:0;padding:0}
    .meal-row{display:grid;grid-template-columns:90px 1fr auto;gap:12px;align-items:center;padding:11px 18px;border-bottom:1px solid var(--line)}
    .meal-row:last-child{border-bottom:none}
    .meal-type{font-size:.72rem;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);font-weight:700}
    .meal-name{font-weight:600;color:var(--ink);font-size:.95rem}
    .meal-cal{font-size:.85rem;color:var(--muted);white-space:nowrap}
    .meal-extra{background:var(--amber-soft)}
    .meal-extra-note{font-weight:400;color:var(--body);font-size:.85rem;line-height:1.4}

    @media(max-width:560px){
      .meal-row{grid-template-columns:1fr auto;gap:4px 12px}
      .meal-type{grid-column:1/-1}
    }

    .plan-related{margin:32px 0 0;display:grid;grid-template-columns:1fr 1fr;gap:12px}
    @media(max-width:600px){.plan-related{grid-template-columns:1fr}}
    .pr-card{display:flex;flex-direction:column;gap:3px;background:#fff;border:1px solid var(--line);border-radius:12px;padding:18px 20px;transition:.15s}
    .pr-recipes{background:var(--paper-2)}
    .pr-card:hover{border-color:var(--accent);text-decoration:none;transform:translateY(-2px)}
    .pr-kicker{font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);font-weight:700}
    .pr-title{font-weight:600;color:var(--ink);font-size:1.02rem;line-height:1.3}
    .pr-go{color:var(--accent);font-weight:600;font-size:.85rem;margin-top:2px}

    .plan-disclaimer{font-size:.78rem;color:var(--muted);margin:28px 0 0;padding-top:16px;border-top:1px solid var(--line);line-height:1.5}

    .print-credit{display:none}
    @media print{
      .site-header,.site-footer,.share-row,.plan-related,.crumbs{display:none !important}
      .plan{padding:0}
      a{color:#000 !important}
      .print-credit{display:block;margin-top:24px;padding-top:12px;border-top:1px solid #ccc;font-size:.8rem;color:#555;text-align:center}
    }
  </style>

  <script>
    const shareBtn = document.getElementById('shareBtn');
    const printBtn = document.getElementById('printBtn');
    const pageUrl = window.location.href;
    const pageTitle = document.title;
    if (shareBtn) {
      if (navigator.share) {
        shareBtn.addEventListener('click', async () => { try { await navigator.share({ title: pageTitle, url: pageUrl }); } catch(e){} });
      } else {
        shareBtn.addEventListener('click', async () => {
          try { await navigator.clipboard.writeText(pageUrl);
            const label = shareBtn.childNodes[shareBtn.childNodes.length-1];
            const o = label.textContent; label.textContent=' Copied!';
            setTimeout(()=>{label.textContent=o;},1800);
          } catch(e){}
        });
      }
    }
    if (printBtn) printBtn.addEventListener('click', () => window.print());
  </script>
</Base>
