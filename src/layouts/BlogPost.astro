---
import Base from './Base.astro';
import JsonLd from '../components/JsonLd.astro';
import Faq from '../components/Faq.astro';

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, relatedCalculators = [], faqs = [] } = post.data;
const url = `https://welanutria.com/blog/${post.slug}/`;

const iso = (d) => new Date(d).toISOString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: url,
  datePublished: iso(pubDate),
  dateModified: iso(updatedDate || pubDate),
  author: { '@type': 'Organization', name: 'welanutria', url: 'https://welanutria.com/' },
  publisher: {
    '@type': 'Organization',
    name: 'welanutria',
    url: 'https://welanutria.com/',
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: 'https://welanutria.com/blog/' },
    { '@type': 'ListItem', position: 2, name: title, item: url },
  ],
};

const dateFmt = new Date(pubDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base title={`${title} | welanutria`} description={description} current="blog" ogType="article">
  <JsonLd schema={articleSchema} />
  <JsonLd schema={breadcrumb} />

  <article class="post wrap">
    <nav class="crumbs"><a href="/blog/">Blog</a> / <span>Article</span></nav>

    <header class="post-head">
      <h1>{title}</h1>
      <p class="post-meta">Published {dateFmt}{updatedDate ? ` · Updated ${new Date(updatedDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}` : ''}</p>
      <div class="share-row">
        <button class="share-btn" id="shareBtn" type="button" aria-label="Share this article">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"/><line x1="15.4" y1="6.5" x2="8.6" y2="10.5"/></svg>
          Share
        </button>
        <button class="share-btn" id="copyBtn" type="button" aria-label="Copy link">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
          <span id="copyLabel">Copy link</span>
        </button>
      </div>
    </header>

    <div class="post-body">
      <slot />
    </div>

    {relatedCalculators.length > 0 && (
      <aside class="related-calcs">
        <h2>Try the calculators</h2>
        <div class="rc-list">
          {relatedCalculators.map((c) => (
            <a class="rc-tile" href={c.href}>
              <span class="rc-name">{c.name}</span>
              <span class="rc-go">Open →</span>
            </a>
          ))}
        </div>
      </aside>
    )}

    {faqs.length > 0 && <div class="post-faq"><Faq items={faqs} /></div>}

    <p class="page-disclaimer">welanutria provides general information and estimates only, and is not medical or dietary advice. Speak with a qualified professional before making significant changes to your diet, exercise or health routine.</p>
  </article>

  <style>
    .post{padding:32px 0 0;max-width:720px}
    .crumbs{font-size:.82rem;color:var(--muted);margin-bottom:16px}
    .crumbs a{color:var(--muted)}
    .post-head{margin-bottom:28px}
    .post-head h1{font-size:clamp(1.9rem,4.5vw,2.6rem);line-height:1.12;letter-spacing:-.02em;margin:0 0 .35em}
    .post-meta{font-size:.85rem;color:var(--muted);margin:0}
    .share-row{display:flex;gap:10px;margin-top:16px}
    .share-btn{display:inline-flex;align-items:center;gap:7px;background:#fff;border:1px solid var(--line);color:var(--ink);font-size:.85rem;font-weight:600;font-family:inherit;padding:8px 14px;border-radius:9px;cursor:pointer;transition:.15s}
    .share-btn:hover{border-color:var(--accent);color:var(--accent)}
    .share-btn svg{color:var(--accent)}
    .post-body{color:#33433D;font-size:1.05rem;line-height:1.7}
    .post-body :global(> p:first-of-type){font-size:1.2rem;line-height:1.6;color:var(--ink);margin-bottom:1.3em}
    .post-body :global(h2){font-size:1.45rem;letter-spacing:-.01em;color:var(--ink);margin:1.8em 0 .5em}
    .post-body :global(h3){font-size:1.15rem;color:var(--ink);margin:1.5em 0 .4em}
    .post-body :global(p){margin:0 0 1.1em}
    .post-body :global(ul),.post-body :global(ol){margin:0 0 1.2em;padding-left:1.4em;line-height:1.7}
    .post-body :global(li){margin:0 0 .5em}
    .post-body :global(strong){color:var(--ink)}
    .post-body :global(a){color:var(--accent);font-weight:500;text-decoration:underline;text-underline-offset:2px}
    .post-body :global(blockquote){margin:1.4em 0;padding:14px 18px;background:var(--cool-2);border-left:3px solid var(--accent);border-radius:8px;color:var(--ink)}
    .post-body :global(blockquote p){margin:0}
    .post-body :global(.key-takeaway){background:var(--paper-2);border:1px solid var(--line);border-radius:12px;padding:18px 20px;margin:1.6em 0}
    .post-body :global(.key-takeaway strong){display:block;font-size:.78rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:6px}
    .post-body :global(.highlight){background:var(--cool-2);border:1px solid var(--cool-line);border-radius:12px;padding:18px 22px;margin:1.6em 0}
    .post-body :global(.highlight p:last-child){margin-bottom:0}
    .post-body :global(.highlight strong){color:var(--ink)}
    .post-body :global(table){width:100%;border-collapse:separate;border-spacing:0;margin:1.6em 0;font-size:.95rem;border:1px solid var(--line);border-radius:12px;overflow:hidden}
    .post-body :global(thead){background:var(--accent)}
    .post-body :global(th){text-align:left;padding:11px 14px;font-size:.74rem;text-transform:uppercase;letter-spacing:.07em;color:#fff;font-weight:700}
    .post-body :global(td){text-align:left;padding:11px 14px;border-top:1px solid var(--line);color:#33433D}
    .post-body :global(tbody tr:nth-child(odd)){background:var(--paper-2)}
    .post-body :global(tbody tr:nth-child(even)){background:#fff}
    .post-body :global(td:first-child){font-weight:600;color:var(--ink)}

    .related-calcs{margin:36px 0 0;background:var(--cool-2);border:1px solid var(--cool-line);border-radius:14px;padding:22px}
    .related-calcs h2{font-size:1.15rem;margin:0 0 14px;color:var(--ink)}
    .rc-list{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    @media(max-width:560px){.rc-list{grid-template-columns:1fr}}
    .rc-tile{display:flex;justify-content:space-between;align-items:center;background:#fff;border:1px solid var(--cool-line);border-radius:10px;padding:13px 15px;transition:.15s}
    .rc-tile:hover{border-color:var(--accent);text-decoration:none}
    .rc-name{font-weight:600;font-size:.95rem;color:var(--ink)}
    .rc-go{color:var(--accent);font-weight:600;font-size:.85rem}

    .post-faq{margin-top:8px}
    .page-disclaimer{font-size:.78rem;color:var(--muted);margin:32px 0 0;padding-top:16px;border-top:1px solid var(--line);line-height:1.5}
  </style>

  <script>
    const shareBtn = document.getElementById('shareBtn');
    const copyBtn = document.getElementById('copyBtn');
    const copyLabel = document.getElementById('copyLabel');
    const pageUrl = window.location.href;
    const pageTitle = document.title;

    if (shareBtn) {
      // If the browser supports native share (mobile mostly), use it; otherwise hide and rely on copy.
      if (navigator.share) {
        shareBtn.addEventListener('click', async () => {
          try {
            await navigator.share({ title: pageTitle, url: pageUrl });
          } catch (e) { /* user cancelled, ignore */ }
        });
      } else {
        shareBtn.style.display = 'none';
      }
    }

    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(pageUrl);
          if (copyLabel) {
            const original = copyLabel.textContent;
            copyLabel.textContent = 'Copied!';
            setTimeout(() => { copyLabel.textContent = original; }, 1800);
          }
        } catch (e) { /* clipboard blocked, ignore */ }
      });
    }
  </script>
</Base>
