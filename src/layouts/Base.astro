---
import '../styles/global.css';

const {
  title = 'welanutria: Free Health & Fitness Calculators',
  description = 'Free, fast health and fitness calculators and recipes. TDEE, BMI, ideal weight, protein, water and body fat. No sign-up.',
  current = '',
  ogType = 'website',
} = Astro.props;

const nav = [
  { href: '/calculators/', label: 'Calculators', key: 'calculators' },
  { href: '/recipes/', label: 'Recipes', key: 'recipes' },
  { href: '/meal-plans/', label: 'Meal Plans', key: 'meal-plans' },
  { href: '/food-lists/', label: 'Food Lists', key: 'food-lists' },
  { href: '/compare/', label: 'Compare', key: 'compare' },
  { href: '/blog/', label: 'Blog', key: 'blog' },
];

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImage = Astro.site ? new URL('/img/og.png', Astro.site).href : '/img/og.png';

// Site-wide Organization + WebSite structured data (appears on every page)
const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://welanutria.com/#organization',
      name: 'welanutria',
      url: 'https://welanutria.com/',
      description: 'Free health and fitness calculators and recipes.',
    },
    {
      '@type': 'WebSite',
      '@id': 'https://welanutria.com/#website',
      url: 'https://welanutria.com/',
      name: 'welanutria',
      description: 'Free health and fitness calculators and recipes.',
      publisher: { '@id': 'https://welanutria.com/#organization' },
    },
  ],
};
