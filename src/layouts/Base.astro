      <nav class="nav" id="nav">
        {nav.map((item) => (
          <a href={item.href} aria-current={current === item.key ? 'page' : undefined}>{item.label}</a>
        ))}
      </nav>
      <button class="menu-btn" id="menu-btn" aria-label="Menu" aria-expanded="false">
        <svg class="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none"><path d="M6 6l12 12M6 18L18 6"/></svg>
      </button>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <div class="f-col">
        <h4>Calculators</h4>
        <ul>
          <li><a href="/calculators/tdee/">TDEE & Macros</a></li>
          <li><a href="/calculators/bmi/">BMI</a></li>
          <li><a href="/calculators/protein/">Protein</a></li>
          <li><a href="/calculators/">All calculators</a></li>
        </ul>
      </div>
      <div class="f-col">
        <h4>Explore</h4>
        <ul>
          <li><a href="/recipes/">Recipes</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/meal-plans/">Meal Plans</a></li>
          <li><a href="/food-lists/">Food Lists</a></li>
        </ul>
      </div>
      <div class="f-col">
        <h4>About</h4>
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/methodology/">Methodology</a></li>
          <li><a href="/privacy/">Privacy</a></li>
          <li><a href="/terms/">Terms</a></li>
        </ul>
      </div>
      <div class="f-bottom">
        © {new Date().getFullYear()} welanutria · Estimates for general information only, not medical advice.
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('nav');
    const iconMenu = btn?.querySelector('.icon-menu');
    const iconClose = btn?.querySelector('.icon-close');
    btn?.addEventListener('click', () => {
      const open = nav?.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.classList.toggle('is-open', open);
      document.body.classList.toggle('menu-open', open);
      if (iconMenu && iconClose) {
        iconMenu.style.display = open ? 'none' : 'block';
        iconClose.style.display = open ? 'block' : 'none';
      }
    });
    // close menu when a link is tapped
    nav?.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        nav.classList.remove('open');
        btn?.classList.remove('is-open');
        document.body.classList.remove('menu-open');
        btn?.setAttribute('aria-expanded', 'false');
        if (iconMenu && iconClose) { iconMenu.style.display = 'block'; iconClose.style.display = 'none'; }
      });
    });
  </script>
</body>
</html>
