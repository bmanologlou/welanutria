---
import Base from './Base.astro';
const { title, description, heading, updated } = Astro.props;
---
<Base title={title} description={description}>
  <article class="prose-page">
    <div class="wrap">
      <h1>{heading}</h1>
      {updated && <p class="updated">Last updated: {updated}</p>}
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>

  <style>
    .prose-page{padding:48px 0 16px}
    .prose-page h1{font-size:clamp(1.8rem,4vw,2.4rem);letter-spacing:-.02em;margin:0 0 .2em}
    .updated{color:var(--muted);font-size:.88rem;margin:0 0 28px}
    .prose{max-width:68ch}
    .prose :global(h2){font-size:1.3rem;letter-spacing:-.01em;margin:1.8em 0 .5em}
    .prose :global(h3){font-size:1.05rem;margin:1.4em 0 .4em}
    .prose :global(p){margin:0 0 1em;color:#33433D;line-height:1.65}
    .prose :global(ul){margin:0 0 1em;padding-left:1.3em;color:#33433D;line-height:1.65}
    .prose :global(li){margin:.3em 0}
    .prose :global(a){color:var(--accent);font-weight:500}
    .prose :global(strong){color:var(--ink)}
    .prose :global(.note){background:var(--cool-2);border:1px solid var(--cool-line);border-radius:12px;padding:14px 16px;font-size:.92rem;color:#33433D}
  </style>
</Base>
